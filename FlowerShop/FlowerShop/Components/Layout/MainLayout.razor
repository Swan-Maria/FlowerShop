@inherits LayoutComponentBase
@using FlowerShop.Client.Components

<MudThemeProvider Theme="_flowerTheme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <NavMenuWrapper @rendermode="InteractiveAuto" />

    <MudMainContent Class="pt-16 px-16">
        <MudContainer Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private MudTheme _flowerTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#8BC34A",         
            Secondary = "#F8BBD0",    
            Background = "#F9FBF9",
            Surface = "#FFFFFF",
            DrawerBackground = "#FDFCFB",
            TextPrimary = "#212121"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px" 
        }
    };
}