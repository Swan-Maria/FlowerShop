@inherits LayoutComponentBase

<MudThemeProvider Theme="_flowerTheme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Primary" Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3 product-title" Color="Color.Inherit">FlowerShop</MudText>
        <MudSpacer/>
        <MudBadge Content="3" Color="Color.Secondary" Overlap="true" Class="mx-4">
            <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Inherit"/>
        </MudBadge>
    </MudAppBar>
    
    <MudDrawer @bind-Open="@_open" Elevation="1">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">FlowerShop</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Match="NavLinkMatch.All">Все товары</MudNavLink>
            <MudNavLink Match="NavLinkMatch.All">Новинки</MudNavLink>
            <MudNavLink Match="NavLinkMatch.All">Букеты</MudNavLink>
            <MudNavLink Match="NavLinkMatch.All">Подарки</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-16">
        <MudContainer Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _open = false;

    private void ToggleDrawer()
    {
        _open = !_open;
    }

    private MudTheme _flowerTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#8BC34A",         
            Secondary = "#F8BBD0",    
            Background = "#F9FBF9",
            Surface = "#FFFFFF",
            DrawerBackground = "#FDFCFB",
            TextPrimary = "#212121"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px" 
        }
    };
}